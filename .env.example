# ─────────────────────────────────────────────────────────────────────────────
# 1SPA PLATFORM - PRODUCTION & DEVELOPMENT ENVIRONMENT CONFIGURATION TEMPLATE
# ─────────────────────────────────────────────────────────────────────────────

# --- Supabase Database & Auth Configuration
# Required for connecting the frontend and server-side operations to Supabase database.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-never-expose-to-client

# --- Upstash Redis / Booking Rate Limiting
# Required to prevent spamming the booking endpoints and ensure API reliability.
UPSTASH_REDIS_REST_URL=https://your-upstash-redis-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-token

# --- Resend Email Gateway Integration
# Optional in dev (falls back gracefully), but required in production to send transactional notifications.
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_DOMAIN=notifications.yourdomain.com
RESEND_ADMIN_FROM=admin.yourdomain.com
ADMIN_EMAIL=admin@yourdomain.com

# --- Site URL / Navigation SEO & Meta Routing
# Used for absolute URL generation in SEO metadata, sitemaps, robots.txt, and onboarding redirects.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Ingestion Pipeline Security Configuration
# Secret authorization key used to secure and validate remote business data ingestion calls.
INGEST_SECRET_KEY=your-highly-secure-ingestion-token
